<?xml version="1.0" encoding="utf-8"?>
<!-- CONSTANT BUTTON (Premium 3D Style) -->

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- PRESSED STATE -->
    <item android:state_pressed="true">

        <layer-list>

            <!-- Bottom Shadow -->
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#08131B"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>

            <!-- Button Face -->
            <item>
                <shape android:shape="rectangle">

                    <gradient
                        android:startColor="@color/bg_const_pressed"
                        android:endColor="#0B1F2A"
                        android:angle="270"/>

                    <stroke
                        android:width="1dp"
                        android:color="#24506B"/>

                    <corners android:radius="8dp"/>

                </shape>
            </item>

        </layer-list>

    </item>

    <!-- NORMAL STATE -->
    <item>

        <layer-list>

            <!-- Bottom Shadow -->
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#050C11"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>

            <!-- Main Button -->
            <item android:bottom="2dp">
                <shape android:shape="rectangle">

                    <gradient
                        android:startColor="#163243"
                        android:centerColor="@color/bg_const"
                        android:endColor="#091822"
                        android:angle="270"/>

                    <stroke
                        android:width="1dp"
                        android:color="#2E6685"/>

                    <corners android:radius="8dp"/>

                </shape>
            </item>

            <!-- Top Highlight -->
            <item
                android:left="1dp"
                android:right="1dp"
                android:top="1dp">

                <shape android:shape="rectangle">

                    <solid android:color="#30FFFFFF"/>

                    <corners android:radius="8dp"/>

                    <size android:height="1dp"/>

                </shape>

            </item>

        </layer-list>

    </item>

</selector>