<?xml version="1.0" encoding="utf-8"?>
<!-- PREMIUM DELETE BUTTON -->

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- PRESSED STATE -->
    <item android:state_pressed="true">

        <layer-list>

            <!-- Bottom Shadow -->
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#2C200D"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>

            <!-- Button Face -->
            <item>
                <shape android:shape="rectangle">

                    <gradient
                        android:startColor="@color/bg_delete_pressed"
                        android:endColor="#4B3512"
                        android:angle="270"/>

                    <stroke
                        android:width="1dp"
                        android:color="#C99A34"/>

                    <corners android:radius="8dp"/>

                </shape>
            </item>

        </layer-list>

    </item>

    <!-- NORMAL STATE -->
    <item>

        <layer-list>

            <!-- Bottom Shadow -->
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#1A1207"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>

            <!-- Main Button -->
            <item android:bottom="2dp">

                <shape android:shape="rectangle">

                    <gradient
                        android:startColor="#5A431A"
                        android:centerColor="@color/bg_delete"
                        android:endColor="#35260D"
                        android:angle="270"/>

                    <stroke
                        android:width="1dp"
                        android:color="#E6B44C"/>

                    <corners android:radius="8dp"/>

                </shape>

            </item>

            <!-- Top Highlight -->
            <item
                android:left="1dp"
                android:right="1dp"
                android:top="1dp">

                <shape android:shape="rectangle">

                    <solid android:color="#40FFFFFF"/>

                    <corners android:radius="8dp"/>

                    <size android:height="1dp"/>

                </shape>

            </item>

        </layer-list>

    </item>

</selector>