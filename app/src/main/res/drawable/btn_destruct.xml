<?xml version="1.0" encoding="utf-8"?>
<!-- PREMIUM AC / CLEAR BUTTON -->

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- PRESSED STATE -->
    <item android:state_pressed="true">

        <layer-list>

            <!-- Bottom Shadow -->
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#3A240C"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>

            <!-- Button Face -->
            <item>
                <shape android:shape="rectangle">

                    <gradient
                        android:startColor="#C08A22"
                        android:endColor="#8A5E16"
                        android:angle="270"/>

                    <stroke
                        android:width="1dp"
                        android:color="#F7D06B"/>

                    <corners android:radius="8dp"/>

                </shape>
            </item>

        </layer-list>

    </item>

    <!-- NORMAL STATE -->
    <item>

        <layer-list>

            <!-- Bottom Shadow -->
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#2B1B09"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>

            <!-- Main Button -->
            <item android:bottom="2dp">

                <shape android:shape="rectangle">

                    <gradient
                        android:startColor="#E0A63B"
                        android:centerColor="#C98D22"
                        android:endColor="#8B621A"
                        android:angle="270"/>

                    <stroke
                        android:width="1dp"
                        android:color="#FFD979"/>

                    <corners android:radius="8dp"/>

                </shape>

            </item>

            <!-- Top Highlight -->
            <item
                android:left="1dp"
                android:right="1dp"
                android:top="1dp">

                <shape android:shape="rectangle">

                    <solid android:color="#40FFFFFF"/>

                    <corners android:radius="8dp"/>

                    <size android:height="1dp"/>

                </shape>

            </item>

        </layer-list>

    </item>

</selector>