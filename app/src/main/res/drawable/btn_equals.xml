<?xml version="1.0" encoding="utf-8"?>
<!-- PREMIUM EQUALS BUTTON -->

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- PRESSED STATE -->
    <item android:state_pressed="true">

        <layer-list>

            <!-- Bottom Shadow -->
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#4A300D"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>

            <!-- Button Face -->
            <item>
                <shape android:shape="rectangle">

                    <gradient
                        android:startColor="#E3A72D"
                        android:endColor="#B77A12"
                        android:angle="270"/>

                    <stroke
                        android:width="1dp"
                        android:color="#FFE082"/>

                    <corners android:radius="8dp"/>

                </shape>
            </item>

        </layer-list>

    </item>

    <!-- NORMAL STATE -->
    <item>

        <layer-list>

            <!-- Bottom Shadow -->
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#332108"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>

            <!-- Main Button -->
            <item android:bottom="2dp">

                <shape android:shape="rectangle">

                    <gradient
                        android:startColor="#FFD86A"
                        android:centerColor="#F2B93A"
                        android:endColor="#C98A17"
                        android:angle="270"/>

                    <stroke
                        android:width="1dp"
                        android:color="#FFF2B0"/>

                    <corners android:radius="8dp"/>

                </shape>

            </item>

            <!-- Top Highlight -->
            <item
                android:left="1dp"
                android:right="1dp"
                android:top="1dp">

                <shape android:shape="rectangle">

                    <solid android:color="#55FFFFFF"/>

                    <corners android:radius="8dp"/>

                    <size android:height="1dp"/>

                </shape>

            </item>

        </layer-list>

    </item>

</selector>