<?xml version="1.0" encoding="utf-8"?>
<!-- PREMIUM SPECIAL FUNCTION BUTTON -->

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- PRESSED -->
    <item android:state_pressed="true">

        <layer-list>

            <!-- Bottom Shadow -->
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#07141B"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>

            <!-- Button Face -->
            <item>
                <shape android:shape="rectangle">

                    <gradient
                        android:startColor="#072537"
                        android:centerColor="#1E5F87"
                        android:endColor="#143F59"
                        android:angle="270"/>

                    <stroke
                        android:width="1dp"
                        android:color="#7FD6FF"/>

                    <corners android:radius="8dp"/>

                </shape>
            </item>

        </layer-list>

    </item>

    <!-- NORMAL -->
    <item>

        <layer-list>

            <!-- Bottom Shadow -->
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#040B10"/>
                    <corners android:radius="8dp"/>
                </shape>
            </item>

            <!-- Main Button -->
            <item android:bottom="2dp">

                <shape android:shape="rectangle">

                    <gradient
                        android:startColor="#3A97CB"
                        android:centerColor="#2874A5"
                        android:endColor="#184C6B"
                        android:angle="270"/>

                    <stroke
                        android:width="1dp"
                        android:color="#A6E4FF"/>

                    <corners android:radius="8dp"/>

                </shape>

            </item>

            <!-- Top Reflection -->
            <item
                android:left="1dp"
                android:right="1dp"
                android:top="1dp">

                <shape android:shape="rectangle">

                    <solid android:color="#45FFFFFF"/>

                    <size android:height="1dp"/>

                    <corners android:radius="8dp"/>

                </shape>

            </item>

        </layer-list>

    </item>

</selector>