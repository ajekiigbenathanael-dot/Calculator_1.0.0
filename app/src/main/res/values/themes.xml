<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- SCIENTIFIC CALCULATOR - LIGHT THEME -->

    <style name="Base.Theme.Calculator"
        parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary Brand Color -->
        <item name="colorPrimary">@color/accent_cyan</item>

        <!-- Primary Variant -->
        <item name="colorPrimaryContainer">@color/bg_display</item>

        <!-- On Primary -->
        <item name="colorOnPrimary">@color/text_primary</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/accent_green</item>

        <!-- Background -->
        <item name="android:windowBackground">@color/bg_primary</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/bg_primary</item>

        <!-- Navigation Bar -->
        <item name="android:navigationBarColor">@color/bg_primary</item>

    </style>

    <style
        name="Theme.Calculator"
        parent="Theme.AppCompat.DayNight.NoActionBar" />

</resources>